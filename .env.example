# FinnSmart environment.
# The app runs fully on realistic mock data with NONE of these set.
# Copy this file to .env.local and fill in your keys to switch to live data —
# no code changes required. NEVER put real keys in this file (it is committed).

# Kimi (Moonshot) — OpenAI-compatible API
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6
# Fast model for relationship-map generation (~1–3s). Avoid kimi-k2.6 here (90s+).
# KIMI_GRAPH_MODEL=moonshot-v1-8k

# Bright Data SERP API
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=

# Token Router — OpenAI-compatible LLM gateway (optional cost router)
TOKEN_ROUTER_API_KEY=
TOKEN_ROUTER_BASE_URL=https://api.tokenrouter.com/v1
# TOKEN_ROUTER_MODEL=moonshotai/kimi-k2.6

# LLM behavior (optional)
# Which provider to try first: "kimi" (default) or "tokenrouter".
# LLM_PRIMARY=kimi
# kimi-k2.6 only accepts temperature = 1; change only if you switch models.
# LLM_TEMPERATURE=1

# Force mock mode even when keys are present (optional)
# FINNSMART_USE_MOCKS=true

# Log per-phase analysis timing to the server terminal + include profile in API response
# FINNSMART_PROFILE=true
